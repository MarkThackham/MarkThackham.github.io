    "#========================================================================\n",
    "# Step 1: Load Data\n",
    "df=pd.read_csv('german_credit.csv')\n",
    "\n",
    "# Bad Flag\n",
    "df['bad_flag']=np.where(df['credit_risk']=='bad', 1, 0)\n",
    "df.drop(columns=['credit_risk'], inplace=True)\n",
    "\n",
    "# Information\n",
    "print('--------------------')\n",
    "print('## Information ##')\n",
    "df.info()\n",
    "print('--------------------')\n",
    "print('')\n",
    "#========================================================================"
   ]
